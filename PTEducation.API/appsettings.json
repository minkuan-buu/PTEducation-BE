{
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_HOST},${DB_PORT};Uid=${DB_USER};Pwd=${DB_PASSWORD};Database=${DB_NAME};Max Pool Size=100;Min Pool Size=5;Pooling=true;TrustServerCertificate=True;Connect Timeout=30;MultipleActiveResultSets=True"
  },
  "CloudflareR2": {
    "AccessKeyId": "${R2_ACCESS_KEY_ID}",
    "SecretAccessKey": "${R2_SECRET_ACCESS_KEY}",
    "ServiceUrl": "${R2_SERVICE_URL}",
    "BucketName": "${R2_BUCKET_NAME}",
    "PublicUrl": "${R2_PUBLIC_URL}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173",
    "http://localhost:5174",
    "https://tradiem.pteducation.edu.vn",
    "https://portal.pteducation.edu.vn"
  ],
  "AllowedHosts": "*"
}